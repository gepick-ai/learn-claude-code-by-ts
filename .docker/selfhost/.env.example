# set the port for the server container it will expose the server on
PORT=3000

# host path of project workspace data to persist
HOST_PROJECT_PATH=~/.gepick/self-host/projects

# host path of sqlite data to persist
HOST_DB_PATH=~/.gepick/self-host/data

# runtime sqlite path inside container
APP_DB_PATH=/app/.data

# runtime project workspace path inside container
APP_PROJECT_PATH=/app/.projects

# model/provider runtime configs
MODEL_ID=
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=
