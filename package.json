{
  "name": "agent-dev",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/opencode-app",
      "apps/opencode-client",
      "packages/learn-claude-code"
    ],
    "catalog": {
      "@ai-sdk/anthropic": "^2.0.0",
      "@anthropic-ai/sdk": "^0.80.0",
