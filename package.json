{
  "name": "gepick",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": {
    "packages": [
      "packages/app",
      "packages/client",
      "packages/core",
      "packages/sdk",
      "packages/ui"
    ],
    "catalog": {
      "@ai-sdk/anthropic": "^2.0.0",
      "@anthropic-ai/sdk": "^0.80.0",
      "@eslint/js": "^10.0.1",
      "@hono/standard-validator": "^0.2.2",
      "@tailwindcss/vite": "^4.2.4",
      "@tsconfig/node22": "^22.0.5",
      "@types/bun": "latest",
      "@types/node": "^25.6.0",
      "@types/pg": "^8.20.0",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "@typescript/native-preview": "7.0.0-dev.20260423.1",
      "@vitejs/plugin-react": "^6.0.1",
      "ai": "^5.0.0",
      "clsx": "^2.1.1",
      "commander": "^14.0.3",
      "dotenv": "^17.3.1",
      "drizzle-kit": "1.0.0-beta.16-ea816b6",
      "drizzle-orm": "1.0.0-beta.16-ea816b6",
      "eslint": "^10.2.1",
      "eslint-config-prettier": "^10.1.8",
      "eslint-plugin-react-hooks": "^7.1.1",
      "eslint-plugin-react-refresh": "^0.5.2",
      "globals": "^17.5.0",
      "hono": "^4.12.14",
      "hono-openapi": "^1.3.0",
      "openai": "^6.33.0",
      "pg": "^8.20.0",
      "prettier": "^3.8.3",
      "react": "^19.2.5",
      "react-dom": "^19.2.5",
      "react-markdown": "^10.1.0",
      "rehype-sanitize": "^6.0.0",
      "rimraf": "^6.0.1",
      "remark-gfm": "^4.0.0",
      "tailwind-merge": "^3.5.0",
      "tailwindcss": "^4.2.4",
      "typescript": "^6.0.3",
      "typescript-eslint": "^8.59.0",
      "vite": "^8.0.9",
      "zod": "^4.3.6"
    }
  },
  "scripts": {
    "postinstall": "bun build:packages",
    "clean:packages": "bun turbo run clean",
    "typecheck:packages": "bun turbo run typecheck",
    "build:packages": "bun turbo run build",
    "build:migration": "bun -F '@gepick/app' db:generate",
    "run:migration": "bun -F '@gepick/app' migrate:apply",
    "build:app": "bun turbo run build --filter=@gepick/app",
    "build:client": "bun turbo run build --filter=@gepick/client",
    "dev:app": "bun -F '@gepick/app' dev",
    "dev:client": "bun -F '@gepick/client' dev"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "turbo": "^2.9.6",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "catalog:",
    "@anthropic-ai/sdk": "catalog:",
    "@hono/standard-validator": "catalog:",
    "@types/pg": "catalog:",
    "ai": "catalog:",
    "commander": "catalog:",
    "drizzle-kit": "catalog:",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "hono-openapi": "catalog:",
    "openai": "catalog:",
    "pg": "catalog:",
    "zod": "catalog:"
  }
}
