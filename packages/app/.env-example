## Anthropic-compatible
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=

MODEL_ID=

# Optional: sqlite data directory (absolute path, or relative to monorepo root)
# If empty, defaults to <monorepo>/.data
APP_DB_PATH=.data

# Optional: project workspace root (absolute path, or relative to monorepo root)
# If empty, defaults to <monorepo>/.projects
APP_PROJECT_PATH=.projects
