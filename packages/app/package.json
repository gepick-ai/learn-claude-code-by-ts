{
  "name": "@gepick/app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "build": "bun clean && bun generate && bun build ./src/index.ts --target bun --outfile ./dist/index.js && bun build ./src/migrate.ts --target bun --outfile ./dist/migrate.js",
    "dev": "bun src/index.ts",
    "migrate": "bun dist/migrate.js",
    "migrate:apply": "bun src/migrate.ts",
    "generate": "bun src/generate.ts",
    "db:push": "bun drizzle-kit push --config drizzle.config.ts",
    "db:generate": "bun drizzle-kit generate --config drizzle.config.ts",
    "build:image": "docker build -f ../../.docker/deployment/app/Dockerfile -t gepick/app:local ../..",
    "push:image": "docker push gepick/app:local"
  },
  "dependencies": {
    "@gepick/core": "workspace:*",
    "@ai-sdk/anthropic": "catalog:",
    "@anthropic-ai/sdk": "catalog:",
    "@hono/standard-validator": "catalog:",
    "@types/pg": "catalog:",
    "ai": "catalog:",
    "commander": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "hono-openapi": "catalog:",
    "openai": "catalog:",
    "pg": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "drizzle-kit": "catalog:",
    "rimraf": "catalog:"
  }
}
