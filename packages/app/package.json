{
  "name": "@gepick/app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && bun run generate && bun build ./src/index.ts --target bun --outfile ./dist/index.js && bun build ./src/migrate.ts --target bun --outfile ./dist/migrate.js",
    "dev": "bun run src/index.ts",
    "migrate": "bun run dist/migrate.js",
    "generate": "bun run src/generate.ts",
    "db:push": "bun drizzle-kit push --config drizzle.config.ts",
    "db:generate": "bun drizzle-kit generate --config drizzle.config.ts"
  },
  "dependencies": {
    "@gepick/core": "workspace:*",
    "@ai-sdk/anthropic": "catalog:",
    "@anthropic-ai/sdk": "catalog:",
    "@hono/standard-validator": "catalog:",
    "@types/pg": "catalog:",
    "ai": "catalog:",
    "commander": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "hono-openapi": "catalog:",
    "openai": "catalog:",
    "pg": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "drizzle-kit": "catalog:"
  }
}
